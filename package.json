{
  "name": "boba-issues",
  "version": "1.0.0",
  "description": "A lightweight, provider-namespaced SDK for issue trackers. Currently supports Jira.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "DOTENV_CONFIG_QUIET=true node --import tsx --test test/*.test.ts"
  },
  "keywords": [
    "jira",
    "issue-tracker",
    "sdk"
  ],
  "author": "Andrew Riggs",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
