# Your Jira Cloud subdomain, e.g. "your-team" for https://your-team.atlassian.net
JIRA_DOMAIN=

# API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_KEY=

# Email address associated with the API token above
JIRA_SERVICE_EMAIL=

# Default project key used when creating issues, e.g. "ENG"
JIRA_PROJECT_KEY=
